    <worksheet name='Revenue by Income Bracket'>
      <table>
        <view>
          <datasources>
            <datasource caption='ml_project1_data' name='federated.0ov4wfp1xkhkks1g4uzfa0srbhnb' />
          </datasources>
          <datasource-dependencies datasource='federated.0ov4wfp1xkhkks1g4uzfa0srbhnb'>
            <column caption='Income Bracket' datatype='string' name='[Calculation_0929138244476931]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Income] &lt; 20000 THEN &apos;Under 20k&apos;&#13;&#10;ELSEIF [Income] &lt;= 40000 THEN &apos;20k-40k&apos;&#13;&#10;ELSEIF [Income] &lt;= 60000 THEN &apos;40k-60k&apos;&#13;&#10;ELSEIF [Income] &lt;= 80000 THEN &apos;60k-80k&apos;&#13;&#10;ELSEIF [Income] &lt;= 100000 THEN &apos;80k-100k&apos;&#13;&#10;ELSEIF [Income] &lt;= 120000 THEN &apos;100k-120k&apos;&#13;&#10;ELSE &apos;120+&apos;&#13;&#10;END' />
            </column>
            <column caption='Absolute Frequency' datatype='integer' name='[Calculation_0929138248355844]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[NumCatalogPurchases] + [NumDealsPurchases] + [NumStorePurchases] + [NumWebPurchases]' />
            </column>
            <column datatype='integer' name='[Income]' role='measure' type='quantitative' />
            <column caption='Num Catalog Purchases' datatype='integer' name='[NumCatalogPurchases]' role='measure' type='quantitative' />
            <column caption='Num Deals Purchases' datatype='integer' name='[NumDealsPurchases]' role='measure' type='quantitative' />
            <column caption='Num Store Purchases' datatype='integer' name='[NumStorePurchases]' role='measure' type='quantitative' />
            <column caption='Num Web Purchases' datatype='integer' name='[NumWebPurchases]' role='measure' type='quantitative' />
            <column caption='Revenue' datatype='integer' name='[Z_Revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0929138244476931]' derivation='None' name='[none:Calculation_0929138244476931:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0929138248355844]' derivation='Sum' name='[sum:Calculation_0929138248355844:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Z_Revenue]' derivation='Sum' name='[sum:Z_Revenue:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0ov4wfp1xkhkks1g4uzfa0srbhnb].[none:Calculation_0929138244476931:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Under 20k&quot;</bucket>
