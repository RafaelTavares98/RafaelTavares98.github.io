    <worksheet name='Product Profitablity Comparison'>
      <table>
        <view>
          <datasources>
            <datasource caption='delivery analysis' name='federated.149p5ng0x5cm6d112yj441pck80k' />
          </datasources>
          <datasource-dependencies datasource='federated.149p5ng0x5cm6d112yj441pck80k'>
            <column caption='Profit (MU)' datatype='real' datatype-customized='true' name='[Calculation_0320834484453378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0320834506809347]-[Z_CostContact]' />
            </column>
            <column caption='Revenue (MU)' datatype='real' name='[Calculation_0320834506809347]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Rule of 3: (Individual Revenue * 3674) / Global Total Revenue&#13;&#10;(([MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]) * 3674) &#13;&#10;/ &#13;&#10;{ FIXED : SUM([MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]) }' />
            </column>
            <column caption='income bracket' datatype='string' name='[Calculation_0320834507677700]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Group Income into 20k intervals&#13;&#10;IF [Income] &lt; 20000 THEN &quot;Under 20k&quot;&#13;&#10;ELSEIF [Income] &lt; 40000 THEN &quot;20k - 39k&quot;&#13;&#10;ELSEIF [Income] &lt; 60000 THEN &quot;40k - 59k&quot;&#13;&#10;ELSEIF [Income] &lt; 80000 THEN &quot;60k - 79k&quot;&#13;&#10;ELSEIF [Income] &lt; 100000 THEN &quot;80k - 99k&quot;&#13;&#10;ELSEIF [Income] &lt; 120000 THEN &quot;100k - 120k&quot;&#13;&#10;ELSE &quot;120k+&quot;&#13;&#10;END' />
            </column>
            <column caption='Product Impact' datatype='real' name='[Calculation_1418971843858433]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Historical Spend] / ({FIXED [ID (product_melt.csv)] : SUM([Historical Spend])})' />
            </column>
            <column caption='Product Revenue (MU)' datatype='real' name='[Calculation_1418971846819843]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Rule of 3: (Individual Revenue * 3674) / Global Total Revenue&#13;&#10;(&#13;&#10;(([MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]) * 3674) &#13;&#10;/ &#13;&#10;{ FIXED : SUM([MntWines] + [MntFruits] + [MntMeatProducts] + [MntFishProducts] + [MntSweetProducts] + [MntGoldProds]) }&#13;&#10;) * [Calculation_1418971843858433]' />
            </column>
            <column datatype='integer' name='[Historical Spend]' role='measure' type='quantitative' />
            <column caption='ID (product melt.csv)' datatype='integer' name='[ID (product_melt.csv)]' role='dimension' type='ordinal' />
            <column datatype='integer' name='[Income]' role='measure' type='quantitative' />
            <column caption='Mnt Fish Products' datatype='integer' name='[MntFishProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Fruits' datatype='integer' name='[MntFruits]' role='measure' type='quantitative' />
            <column caption='Mnt Gold Prods' datatype='integer' name='[MntGoldProds]' role='measure' type='quantitative' />
            <column caption='Mnt Meat Products' datatype='integer' name='[MntMeatProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Sweet Products' datatype='integer' name='[MntSweetProducts]' role='measure' type='quantitative' />
            <column caption='Mnt Wines' datatype='integer' name='[MntWines]' role='measure' type='quantitative' />
            <column datatype='string' name='[Product Category]' role='dimension' type='nominal' />
            <column caption='Cost to Contact (MU)' datatype='real' datatype-customized='true' name='[Z_CostContact]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0320834507677700]' derivation='None' name='[none:Calculation_0320834507677700:nk]' pivot='key' type='nominal' />
            <column-instance column='[Product Category]' derivation='None' name='[none:Product Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0320834484453378]' derivation='Sum' name='[sum:Calculation_0320834484453378:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1418971846819843]' derivation='Sum' name='[sum:Calculation_1418971846819843:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.149p5ng0x5cm6d112yj441pck80k].[none:Calculation_0320834507677700:nk]' direction='ASC'>
