            <column caption='Cost to Contact (MU)' datatype='real' datatype-customized='true' name='[Z_CostContact]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0320834484453378]' derivation='None' name='[none:Calculation_0320834484453378:qk]' pivot='key' type='quantitative' />
