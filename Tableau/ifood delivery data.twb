            <column-instance column='[Z_Revenue]' derivation='Sum' name='[sum:Z_Revenue:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0ov4wfp1xkhkks1g4uzfa0srbhnb].[none:Calculation_0929138244476931:nk]' direction='ASC'>
