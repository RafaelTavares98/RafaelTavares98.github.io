            <column caption='Revenue' datatype='integer' name='[Z_Revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0929138244476931]' derivation='None' name='[none:Calculation_0929138244476931:nk]' pivot='key' type='nominal' />
